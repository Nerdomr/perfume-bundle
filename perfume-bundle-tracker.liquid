{% comment %}
  ┌──────────────────────────────────────────────────────────────┐
  │  Perfume Bundle Tracker — Quiet Luxury Theme Section         │
  │  Drop this in: sections/perfume-bundle-tracker.liquid        │
  │                                                              │
  │  Renders the 4-slot visual tracker. On slot 4 filling,       │
  │  calls /cart/add.js with all 4 variant IDs in one request.   │
  └──────────────────────────────────────────────────────────────┘
{% endcomment %}

{{ 'perfume-bundle-tracker.css' | asset_url | stylesheet_tag }}

<section class="pbt-section" data-section-id="{{ section.id }}">
  <div class="pbt-header">
    <h2 class="pbt-heading">{{ section.settings.heading }}</h2>
    <p class="pbt-subheading">{{ section.settings.subheading }}</p>
  </div>

  {%- comment -%} Perfume cards — rendered server-side from collection {%- endcomment -%}
  <div class="pbt-grid" role="list">
    {%- for product in collections[section.settings.collection_handle].products -%}
      {%- assign variant = product.variants.first -%}
      <div
        class="pbt-card"
        role="listitem"
        data-variant-id="{{ variant.id }}"
        data-product-title="{{ product.title | escape }}"
        data-product-image="{{ product.featured_image | image_url: width: 120 }}"
        tabindex="0"
        aria-label="Select {{ product.title }}"
      >
        <div class="pbt-card__badge" aria-hidden="true">
          <svg viewBox="0 0 10 8" fill="none" width="10" height="8">
            <path d="M1 4L3.8 7L9 1" stroke="currentColor" stroke-width="1.3"
              stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>

        {{- product.featured_image
          | image_url: width: 200
          | image_tag:
              class: 'pbt-card__image',
              alt: product.title,
              loading: 'lazy'
        -}}

        <div class="pbt-card__meta">
          <p class="pbt-card__name">{{ product.title }}</p>
          <p class="pbt-card__price">{{ variant.price | money }}</p>
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- comment -%} 4-Slot tracker bar {%- endcomment -%}
  <div class="pbt-tracker" aria-live="polite" aria-label="Bundle tracker">
    <p class="pbt-tracker__label">{{ 'sections.bundle_tracker.label' | t | default: 'Your curated set' }}</p>

    <div class="pbt-slots" role="list">
      {%- for i in (1..4) -%}
        <div class="pbt-slot" id="pbt-slot-{{ i }}" role="listitem" aria-label="Slot {{ i }}">
          <div class="pbt-slot__inner">
            <img class="pbt-slot__thumb" src="" alt="" aria-hidden="true" />
            <span class="pbt-slot__name"></span>
          </div>
          <span class="pbt-slot__ordinal" aria-hidden="true">{{ i }}</span>
        </div>
      {%- endfor -%}
    </div>

    <div class="pbt-progress">
      <div class="pbt-progress__bar">
        <div class="pbt-progress__fill" id="pbt-progress-fill" style="width: 0%"></div>
      </div>
      <span class="pbt-progress__count" id="pbt-count">0 / 4</span>
    </div>

    <div class="pbt-cta" id="pbt-cta" aria-hidden="true">
      <p class="pbt-cta__price">
        {{ 'sections.bundle_tracker.bundle_price' | t | default: 'Bundle — $100 · 15% off' }}
      </p>
      <button class="pbt-cta__btn" id="pbt-add-btn" type="button" disabled>
        {{ 'sections.bundle_tracker.add_to_cart' | t | default: 'Add bundle to cart' }}
        <span class="pbt-cta__spinner" aria-hidden="true"></span>
      </button>
      <p class="pbt-cta__note" role="status" id="pbt-status"></p>
    </div>
  </div>
</section>

<script>
(function () {
  'use strict';

  // ── State ───────────────────────────────────────────────────
  const MAX = 4;
  let selected = []; // array of { variantId, title, image }

  // ── DOM refs ────────────────────────────────────────────────
  const cards   = document.querySelectorAll('.pbt-card');
  const slots   = document.querySelectorAll('.pbt-slot');
  const fill    = document.getElementById('pbt-progress-fill');
  const count   = document.getElementById('pbt-count');
  const cta     = document.getElementById('pbt-cta');
  const addBtn  = document.getElementById('pbt-add-btn');
  const status  = document.getElementById('pbt-status');

  // ── Card interaction ────────────────────────────────────────
  cards.forEach(card => {
    card.addEventListener('click', () => toggle(card));
    card.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(card); }
    });
  });

  function toggle(card) {
    const id    = card.dataset.variantId;
    const idx   = selected.findIndex(s => s.variantId === id);

    if (idx > -1) {
      selected.splice(idx, 1);
    } else {
      if (selected.length >= MAX) return;
      selected.push({
        variantId : id,
        title     : card.dataset.productTitle,
        image     : card.dataset.productImage,
      });
    }
    render();
  }

  // ── Render ──────────────────────────────────────────────────
  function render() {
    const n = selected.length;

    // Cards
    cards.forEach(card => {
      const id    = card.dataset.variantId;
      const inSel = selected.some(s => s.variantId === id);
      card.classList.toggle('is-selected', inSel);
      card.classList.toggle('is-disabled', !inSel && n >= MAX);
      card.setAttribute('aria-pressed', inSel ? 'true' : 'false');
    });

    // Slots — fade-in transition handled via CSS .is-filled
    slots.forEach((slot, i) => {
      const item   = selected[i];
      const thumb  = slot.querySelector('.pbt-slot__thumb');
      const name   = slot.querySelector('.pbt-slot__name');
      const filled = !!item;

      if (filled) {
        thumb.src = item.image;
        thumb.alt = item.title;
        name.textContent = item.title;
      } else {
        thumb.src = '';
        thumb.alt = '';
        name.textContent = '';
      }

      // Defer adding class so transition plays after image loads
      requestAnimationFrame(() => slot.classList.toggle('is-filled', filled));
    });

    // Progress bar
    fill.style.width = (n / MAX * 100) + '%';
    count.textContent = n + ' / ' + MAX;

    // CTA
    const ready = n === MAX;
    cta.setAttribute('aria-hidden', ready ? 'false' : 'true');
    cta.classList.toggle('is-visible', ready);
    addBtn.disabled = !ready;
    status.textContent = '';
  }

  // ── Add to cart — single AJAX call ─────────────────────────
  addBtn.addEventListener('click', addBundle);

  async function addBundle() {
    if (selected.length < MAX) return;

    addBtn.disabled = true;
    addBtn.classList.add('is-loading');
    status.textContent = '';

    // Build items array: all 4 variants in ONE /cart/add.js call
    const items = selected.map(s => ({
      id       : parseInt(s.variantId, 10),
      quantity : 1,
      properties: {
        '_bundle' : 'perfume-set-4',
      }
    }));

    try {
      const res = await fetch('/cart/add.js', {
        method  : 'POST',
        headers : { 'Content-Type': 'application/json' },
        body    : JSON.stringify({ items }),
      });

      if (!res.ok) throw new Error(res.statusText);

      status.textContent = '{{ "sections.bundle_tracker.success" | t | default: "Added to your cart." }}';

      // Optional: redirect to cart
      // window.location.href = '/cart';

      // Reset UI
      selected = [];
      render();

    } catch (err) {
      console.error('[pbt] cart/add.js error', err);
      status.textContent = '{{ "sections.bundle_tracker.error" | t | default: "Something went wrong. Please try again." }}';
    } finally {
      addBtn.disabled = false;
      addBtn.classList.remove('is-loading');
    }
  }

  // Init
  render();
})();
</script>

{% schema %}
{
  "name": "Perfume Bundle Tracker",
  "tag": "section",
  "class": "perfume-bundle-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Compose Your Collection"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Select any four — your bundle, your signature."
    },
    {
      "type": "collection",
      "id": "collection_handle",
      "label": "Perfumes collection"
    }
  ],
  "presets": [
    {
      "name": "Perfume Bundle Tracker"
    }
  ]
}
{% endschema %}
